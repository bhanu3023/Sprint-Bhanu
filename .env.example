# Database - Use the same username/password you use for PostgreSQL (pgAdmin, etc.)
# Format: postgresql://USERNAME:PASSWORD@localhost:5432/sprintboard?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/sprintboard?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-in-production-min-32-chars"

# Optional: Email (for password reset notifications)
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="your@email.com"
EMAIL_SERVER_PASSWORD="your-app-password"
EMAIL_FROM="Sprint Board <noreply@sprintboard.app>"

# Optional: File uploads (defaults to local ./public/uploads)
UPLOAD_PROVIDER="local"
# For S3: UPLOAD_PROVIDER="s3"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="us-east-1"
# AWS_S3_BUCKET=""
